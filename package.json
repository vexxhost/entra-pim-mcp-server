{
  "name": "entra-pim-mcp-server",
  "version": "0.1.0",
  "description": "MCP server for Azure Entra PIM — list eligible assignments and activate group/role assignments",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "entra-pim-mcp-server": "dist/index.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "prepare": "npm run build",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@azure/identity": "^4.13.0",
    "@azure/identity-cache-persistence": "^1.2.0",
    "@microsoft/kiota-authentication-azure": "^1.0.0-preview.100",
    "@microsoft/msgraph-sdk": "^1.0.0-preview.80",
    "@microsoft/msgraph-sdk-identitygovernance": "^1.0.0-preview.80",
    "@microsoft/msgraph-sdk-policies": "^1.0.0-preview.80",
    "@microsoft/msgraph-sdk-rolemanagement": "^1.0.0-preview.80",
    "@microsoft/msgraph-sdk-users": "^1.0.0-preview.80",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "env-paths": "^4.0.0",
    "undici": "^7.22.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.57.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
